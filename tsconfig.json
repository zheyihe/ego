{
	"extends": "./tsconfig.base.json",
	"compilerOptions": {
		"noEmit": true,
		"paths": {
			"*": ["./*"],
			"@zheyihe/ego-ai": ["./packages/ai/src/index.ts"],
			"@zheyihe/ego-ai/oauth": ["./packages/ai/src/oauth.ts"],
			"@zheyihe/ego-ai/*": ["./packages/ai/src/*.ts", "./packages/ai/src/providers/*.ts"],
			"@zheyihe/ego-ai/dist/*": ["./packages/ai/src/*"],
			"@zheyihe/ego-agent-core": ["./packages/agent/src/index.ts"],
			"@zheyihe/ego-agent-core/*": ["./packages/agent/src/*"],
			"@zheyihe/ego-coding-agent": ["./packages/coding-agent/src/index.ts"],
			"@zheyihe/ego-coding-agent/hooks": ["./packages/coding-agent/src/core/hooks/index.ts"],
			"@zheyihe/ego-coding-agent/*": ["./packages/coding-agent/src/*"],
			"typebox": ["./node_modules/typebox"],
			"@zheyihe/ego-mom": ["./packages/mom/src/index.ts"],
			"@zheyihe/ego-mom/*": ["./packages/mom/src/*"],
			"@zheyihe/ego-pods": ["./packages/pods/src/index.ts"],
			"@zheyihe/ego-pods/*": ["./packages/pods/src/*"],
			"@zheyihe/ego-tui": ["./packages/tui/src/index.ts"],
			"@zheyihe/ego-tui/*": ["./packages/tui/src/*"],
			"@zheyihe/ego-web-ui": ["./packages/web-ui/src/index.ts"],
			"@zheyihe/ego-web-ui/*": ["./packages/web-ui/src/*"],
			"@zheyihe/ego-pods-agent-old": ["./packages/agent-old/src/index.ts"],
			"@zheyihe/ego-pods-agent-old/*": ["./packages/agent-old/src/*"]
		}
	},
	"include": ["packages/*/src/**/*", "packages/*/test/**/*", "packages/coding-agent/examples/**/*"],
	"exclude": ["packages/web-ui/**/*", "**/dist/**"]
}
