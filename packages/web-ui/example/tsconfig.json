{
	"compilerOptions": {
		"target": "ES2022",
		"module": "ES2022",
		"lib": ["ES2022", "DOM", "DOM.Iterable"],
		"moduleResolution": "bundler",
		"paths": {
			"*": ["./*"],
			"@zheyihe/ego-agent-core": ["../../agent/src/index.ts"],
			"@zheyihe/ego-ai": ["../../ai/src/index.ts"],
			"@zheyihe/ego-ai/*": ["../../ai/src/*", "../../ai/src/providers/*"],
			"@zheyihe/ego-tui": ["../../tui/src/index.ts"],
			"@zheyihe/ego-web-ui": ["../src/index.ts"],
			"@zheyihe/ego-web-ui/*": ["../src/*"]
		},
		"strict": true,
		"skipLibCheck": true,
		"esModuleInterop": true,
		"allowSyntheticDefaultImports": true,
		"experimentalDecorators": true,
		"useDefineForClassFields": false
	},
	"include": ["src/**/*"],
	"exclude": ["../src"]
}
